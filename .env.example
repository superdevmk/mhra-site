# Supabase (server-side only — never expose service role in frontend)
SUPABASE_URL=https://lqhtqxuiahivairqaoeb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Site URL for return links (no trailing slash)
SITE_URL=https://your-domain.vercel.app

# Ticket pricing in whole MKD (cPay sends amount × 100)
MHRA_TICKET_EARLY_BIRD_MKD=4500
MHRA_TICKET_REGULAR_MKD=6000
MHRA_TICKET_EARLY_BIRD_UNTIL=2026-09-01

# mock = test checkout without cPay | live = real cPay API
CPAY_MODE=mock

# cPay credentials (from bank ZIP — required when CPAY_MODE=live)
CPAY_MERCHANT_TIN=
CPAY_MERCHANT_PASSWORD=
CPAY_MERCHANT_NAME=
CPAY_SERVER_PUBLIC_KEY_PEM=
CPAY_CLIENT_PRIVATE_KEY_PEM=

# Bank transfer fallback (shown on checkout + confirmation)
MHRA_BANK_NAME=
MHRA_BANK_IBAN=
MHRA_BANK_SWIFT=
MHRA_BANK_RECIPIENT=Macedonian Human Resources Association (MHRA)
